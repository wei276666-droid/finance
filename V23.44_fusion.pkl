"""
V23.44 融合版 = V23.39(特殊事件二叉树+滚动数据) + V23.43(β放大+自动学习)
修复内容:
1. β缩放因子从0.4提升到0.7
2. 保留特殊事件二叉树模型
3. 保留自动学习模块
4. 优化回调检测
5. 添加下跌事件库
"""

import numpy as np
from collections import deque
from datetime import datetime, timedelta
import pickle
import warnings
warnings.filterwarnings('ignore')


# ========== 1. 滚动市场数据存储器 ==========
class RollingMarketData:
    def __init__(self, window_days=30):
        self.window_days = window_days
        self.sector_returns = {}
        self.market_breadth = deque(maxlen=window_days)
        self.northbound_flow = deque(maxlen=window_days)
        self.fear_greed_index = deque(maxlen=window_days)
        self.dates = deque(maxlen=window_days)
        self.up_count_history = deque(maxlen=window_days)
        self.down_count_history = deque(maxlen=window_days)
    
    def update(self, date, sector_returns, market_breadth, northbound_flow, 
               fear_greed_index, up_count=None, down_count=None):
        for sector, ret in sector_returns.items():
            if sector not in self.sector_returns:
                self.sector_returns[sector] = deque(maxlen=self.window_days)
            self.sector_returns[sector].append(ret)
        
        if market_breadth is not None:
            self.market_breadth.append(market_breadth)
        if northbound_flow is not None:
            self.northbound_flow.append(northbound_flow)
        if fear_greed_index is not None:
            self.fear_greed_index.append(fear_greed_index)
        if up_count is not None:
            self.up_count_history.append(up_count)
        if down_count is not None:
            self.down_count_history.append(down_count)
        
        self.dates.append(date)
    
    def get_consecutive_gains(self, sector, threshold=1.0):
        returns = self.sector_returns.get(sector, [])
        if len(returns) < 2:
            return 0
        count = 0
        for ret in reversed(returns):
            if ret > threshold:
                count += 1
            else:
                break
        return count
    
    def get_prev_day_up_count(self):
        if len(self.up_count_history) >= 1:
            return self.up_count_history[-1]
        return 0
    
    def get_prev_day_breadth(self):
        if len(self.market_breadth) >= 1:
            return self.market_breadth[-1]
        return 0.5


# ========== 2. 特殊事件二叉树模型（优化） ==========
class SpecialEventTree:
    """
    特殊事件二叉树 - 基于历史统计规律自动匹配下跌预判
    """
    
    def __init__(self):
        self.downturn_patterns = {
            '科技暴涨后回调': {
                'trigger': {'tech_gain': 3.0, 'breadth': 0.55},
                'severity': 'moderate',
                'expected_change': -0.8,
                'affected_sectors': ['半导体及元件', '计算机应用', '通信设备', '电子'],
                'confidence': 0.75
            },
            '普涨后回调': {
                'trigger': {'up_count': 5000},
                'severity': 'mild',
                'expected_change': -0.5,
                'affected_sectors': ['前期热门', '商业航天', '军工信息化'],
                'confidence': 0.65
            },
            '获利了结轮动': {
                'trigger': {'轮动': True},
                'severity': 'moderate',
                'expected_change': -0.6,
                'affected_sectors': ['前期大涨科技股', '商业航天'],
                'rotation_up': ['煤炭开采加工', '医药生物', '电力设备'],
                'confidence': 0.70
            },
            '节前避险': {
                'trigger': {'days_to_holiday': 3},
                'severity': 'mild',
                'expected_change': -0.3,
                'affected_sectors': ['科技成长', '小金属', '能源金属'],
                'confidence': 0.55
            }
        }
    
    def match(self, prev_day_data, rolling_data):
        matched = []
        
        tech_gain = max([
            prev_day_data.get('半导体及元件', 0),
            prev_day_data.get('计算机应用', 0),
            prev_day_data.get('通信设备', 0)
        ])
        prev_breadth = rolling_data.get_prev_day_breadth() if rolling_data else 0.5
        
        if tech_gain > 3.0 and prev_breadth > 0.55:
            matched.append(self.downturn_patterns['科技暴涨后回调'])
        
        prev_up_count = rolling_data.get_prev_day_up_count() if rolling_data else 0
        if prev_up_count > 5000:
            matched.append(self.downturn_patterns['普涨后回调'])
        
        return matched
    
    def apply_downturn(self, predictions, matched_patterns):
        for pattern in matched_patterns:
            for sector in pattern.get('affected_sectors', []):
                for p in predictions['top_gainers']:
                    if sector in p['sector']:
                        original = p['prediction']
                        p['prediction'] = round(original * pattern['expected_change'] / 3, 2)
                        p['special_downturn'] = True
                        p['downturn_reason'] = pattern
            
            for sector in pattern.get('rotation_up', []):
                for p in predictions['top_gainers']:
                    if sector in p['sector']:
                        p['prediction'] = round(p['prediction'] * 1.2, 2)
        
        predictions['top_gainers'].sort(key=lambda x: x['prediction'], reverse=True)
        predictions['top_losers'].sort(key=lambda x: x['prediction'])
        
        return predictions


# ========== 3. 自动学习模块 ==========
class AutoBetaLearner:
    def __init__(self):
        self.current_beta = {}
    
    def get_beta(self, event_type, sector, default_beta=0.5):
        key = f"{event_type}|{sector}"
        return self.current_beta.get(key, default_beta)
    
    def auto_update(self, event_type, sector, event_score, predicted_impact, actual_gain, date):
        if event_score <= 0:
            return
        key = f"{event_type}|{sector}"
        actual_beta = actual_gain / (event_score / 3)
        actual_beta = max(-3.0, min(3.0, actual_beta))
        old_beta = self.current_beta.get(key, 0.5)
        new_beta = old_beta * 0.7 + actual_beta * 0.3
        self.current_beta[key] = round(new_beta, 3)


class AutoCorrectionLearner:
    def __init__(self):
        self.correction_history = deque(maxlen=50)
    
    def get_factor(self, prev_gain, prev_breadth, current_breadth, northbound_change):
        if prev_gain > 3.0 and northbound_change < -50 and current_breadth < 0.45:
            return 0.5
        elif prev_gain > 2.0 and current_breadth < 0.5:
            return 0.7
        else:
            return 1.0


# ========== 4. 滚动校准器 ==========
class RollingCalibrator:
    def __init__(self, window_days=10):
        self.window_days = window_days
        self.history = deque(maxlen=window_days)
        self.recent_style = 'growth'
        self.market_breadth_history = deque(maxlen=10)
        self.northbound_history = deque(maxlen=10)
        self.actual_market_breadth = deque(maxlen=5)
        self.fear_greed_index = 50
        self.set_initial_breadth(0.5)
    
    def add_observation(self, date, events, gainers, losers, market_breadth=None, northbound_flow=None, actual_breadth=None):
        self.history.append({'date': date, 'events': events, 'gainers': gainers[:5], 'losers': losers[:5]})
        if market_breadth is not None:
            self.market_breadth_history.append(market_breadth)
        if northbound_flow is not None:
            self.northbound_history.append(northbound_flow)
        if actual_breadth is not None:
            self.actual_market_breadth.append(actual_breadth)
            if actual_breadth > 0.7:
                self.fear_greed_index = min(100, self.fear_greed_index + 8)
            elif actual_breadth < 0.3:
                self.fear_greed_index = max(0, self.fear_greed_index - 8)
        self._update_style()
    
    def _update_style(self):
        if len(self.history) < 3:
            return
        up_freq = {}
        for day in self.history:
            for sector in day['gainers']:
                up_freq[sector] = up_freq.get(sector, 0) + 1
        growth_score = sum([up_freq.get(s, 0) for s in ['电子', '计算机', '通信', '传媒', '电力设备']])
        value_score = sum([up_freq.get(s, 0) for s in ['银行', '煤炭', '钢铁', '房地产']])
        defensive_score = sum([up_freq.get(s, 0) for s in ['公用事业', '食品饮料', '医药生物']])
        if growth_score > value_score and growth_score > defensive_score:
            self.recent_style = 'growth'
        elif value_score > defensive_score:
            self.recent_style = 'value'
        else:
            self.recent_style = 'defensive'
    
    def get_style_weight(self, sector, is_up=True):
        style_config = {
            'growth': {'up': ['电子', '计算机', '通信', '传媒', '电力设备', '医药生物'], 'down': ['煤炭', '钢铁', '银行', '房地产']},
            'value': {'up': ['银行', '煤炭', '钢铁', '房地产', '建筑装饰'], 'down': ['电子', '计算机', '通信', '传媒']},
            'defensive': {'up': ['公用事业', '食品饮料', '医药生物', '农林牧渔'], 'down': ['有色金属', '基础化工', '钢铁']}
        }
        style = self.recent_style
        if is_up:
            if sector in style_config.get(style, {}).get('up', []):
                return 1.15
        else:
            if sector in style_config.get(style, {}).get('down', []):
                return 1.1
        return 1.0
    
    def get_rolling_beta_adjustment(self, event_type, sector):
        if len(self.history) < 5:
            return 1.0
        return 1.0
    
    def get_market_state(self):
        if len(self.actual_market_breadth) >= 2:
            avg_breadth = np.mean(list(self.actual_market_breadth)[-2:])
            if avg_breadth > 0.65:
                return 'bull'
            elif avg_breadth < 0.35:
                return 'bear'
            else:
                return 'range'
        if len(self.market_breadth_history) >= 3:
            avg_breadth = np.mean(list(self.market_breadth_history)[-3:])
            if avg_breadth > 0.60:
                return 'bull'
            elif avg_breadth < 0.35:
                return 'bear'
        return 'range'
    
    def get_incremental_capital_factor(self):
        state = self.get_market_state()
        if state == 'bull':
            return 0.75
        elif state == 'bear':
            return 0.20
        else:
            return 0.50
    
    def get_friction_cost(self):
        state = self.get_market_state()
        if state == 'bull':
            return 0.96
        elif state == 'bear':
            return 0.80
        else:
            return 0.90
    
    def get_max_single_down(self):
        state = self.get_market_state()
        if state == 'bull':
            return -0.5
        elif state == 'bear':
            return -1.0
        else:
            return -0.6
    
    def get_victim_multiplier(self):
        state = self.get_market_state()
        if state == 'bull':
            return 3
        elif state == 'bear':
            return 7
        else:
            return 5
    
    def get_macro_base(self, northbound_flow=None):
        if northbound_flow is not None:
            if northbound_flow < -100:
                return -0.065
            elif northbound_flow < -50:
                return -0.03
            elif northbound_flow < 0:
                return -0.01
            elif northbound_flow > 100:
                return 0.08
            elif northbound_flow > 50:
                return 0.03
            else:
                return 0.01
        
        state = self.get_market_state()
        if state == 'bull':
            return 0.05
        elif state == 'bear':
            return -0.05
        else:
            return 0.02
    
    def get_fear_greed_multiplier(self):
        fg = self.fear_greed_index
        if fg > 70:
            return 1.2
        elif fg < 30:
            return 0.8
        else:
            return 1.0
    
    def set_initial_breadth(self, breadth):
        self.market_breadth_history.append(breadth)
        self.actual_market_breadth.append(breadth)


# ========== 5. 周末新闻处理器 ==========
class WeekendNewsProcessor:
    def process_weekend_news(self, news_list, current_date):
        processed = []
        for news in news_list:
            strength = news['strength']
            desc = news.get('description', '')
            if '周六' in desc or '星期六' in desc:
                strength *= 0.9
            elif '周日' in desc or '星期日' in desc:
                strength *= 0.8
            processed.append({**news, 'strength': round(strength, 2)})
        
        event_groups = {}
        for news in processed:
            et = news['event_type']
            if et not in event_groups:
                event_groups[et] = []
            event_groups[et].append(news)
        
        result = []
        for et, group in event_groups.items():
            if len(group) >= 2:
                base_strength = max([n['strength'] for n in group])
                enhanced_strength = min(1.0, base_strength * (1 + 0.1 * (len(group) - 1)))
                group[0]['strength'] = round(enhanced_strength, 2)
                result.append(group[0])
            else:
                result.append(group[0])
        return result


# ========== 6. 边际效用跟踪器 ==========
class DiminishingReturnsTracker:
    def __init__(self):
        self.event_counts = {}
    
    def update(self, event_type):
        if event_type not in self.event_counts:
            self.event_counts[event_type] = 0
        self.event_counts[event_type] += 1
    
    def get_multiplier(self, event_type):
        count = self.event_counts.get(event_type, 0)
        if count == 0 or count == 1:
            return 1.0
        elif count == 2:
            return 0.7
        elif count == 3:
            return 0.5
        elif count == 4:
            return 0.3
        else:
            return 0.2


# ========== 7. 预期差调整器 ==========
class ExpectationAdjuster:
    def __init__(self):
        self.thresholds = {
            '国防军工': 2.0,
            '通信设备': 1.8,
            '半导体及元件': 1.5,
            '计算机应用': 1.5,
            '油气开采及服务': 1.5,
        }
        self.event_sensitivity = {
            '航天日': 0.6,
            '军工政策': 0.6,
            '科技政策': 0.4,
            '通信政策': 0.4,
        }
    
    def get_adjustment_factor(self, sector, event_type, pre_event_gain):
        if pre_event_gain is None:
            return 1.0
        
        threshold = self.thresholds.get(sector, 2.0)
        sensitivity = self.event_sensitivity.get(event_type, 0.3)
        
        if pre_event_gain <= threshold:
            return 1.0
        
        excess = (pre_event_gain - threshold) / 3
        factor = max(0.3, 1.0 - sensitivity - excess * 0.2)
        
        return round(factor, 2)


