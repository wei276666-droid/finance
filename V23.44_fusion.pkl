        self.rolling_market_data = RollingMarketData(window_days=30)
        self.special_event_tree = SpecialEventTree()
        self.beta_learner = AutoBetaLearner()
        self.correction_learner = AutoCorrectionLearner()
        
        self.industry_chain = self._get_industry_chain()
    
    def _get_scaled_beta(self):
        """缩放后的β系数（scale=0.7）"""
        scale = self.BETA_SCALE
        
        base_beta = {
            # 正向事件
            '科技政策': {'电子': 1.2, '计算机': 0.5, '通信': 0.5},
            '算力政策': {'电子': 1.2, '计算机': 0.5, '通信': 0.5, '电力设备': 0.6},
            '新能源政策': {'电力设备': 1.4, '小金属': 1.2, '能源金属': 1.2, '电池': 1.0, '汽车': 0.8},
            '货币政策': {'银行': 0.5, '证券': 0.6},
            '房地产政策': {'房地产': 1.0, '建筑材料': 0.6, '家用电器': 0.5},
            '消费刺激': {'食品饮料': 0.6, '家用电器': 0.7, '汽车': 0.6},
            '宏观数据': {'银行': 0.3, '证券': 0.3, '食品饮料': 0.3},
            '中东局势': {'石油石化': 1.0, '煤炭': 0.6, '国防军工': 0.3},
            '原油价格上涨': {'石油石化': 1.2, '煤炭': 0.7},
            
            # 负向事件（新增）
            '银行利空': {'银行': -0.8},
            '油价下跌': {'石油石化': -1.0, '煤炭': -0.5},
            '消费利空': {'食品饮料': -0.6, '家用电器': -0.4},
            '市场回调': {'电子': -0.6, '计算机': -0.4, '通信': -0.4},
            '获利了结': {'科技成长': -0.4},
        }
        
        scaled_beta = {}
        for event, sectors in base_beta.items():
            scaled_beta[event] = {}
            for sector, beta in sectors.items():
                scaled_beta[event][sector] = round(beta * scale, 2)
        
        return scaled_beta
    
    def get_beta(self, event_type, sector):
        """获取动态β（支持自动学习）"""
        default = self.event_beta.get(event_type, {}).get(sector, 0.3)
        return self.beta_learner.get_beta(event_type, sector, default)
    
    def _get_vulnerability(self):
        vuln = {s: 0.4 for s in self.sectors}
        vuln['钢铁'] = 0.65
        vuln['基础化工'] = 0.5
        vuln['有色金属'] = 0.45
        vuln['石油石化'] = 0.2
        vuln['煤炭'] = 0.25
        vuln['银行'] = 0.15
        vuln['小金属'] = 0.3
        vuln['能源金属'] = 0.3
        vuln['电池'] = 0.35
        return vuln
    
    def _get_macro_sensitivity(self):
        return {s: 0.3 for s in self.sectors}
    
    def _get_industry_chain(self):
        return {
            '新能源政策': {
                'name': '新能源汽车产业链',
                'path': '上游锂矿/化工 → 中游电池/设备 → 下游整车',
                'upstream': ['有色金属', '基础化工', '小金属', '能源金属'],
                'midstream': ['电力设备', '电池'],
                'downstream': ['汽车']
            },
            '算力政策': {
                'name': 'AI算力产业链',
                'path': '上游芯片/设备 → 中游算力建设 → 下游应用',
                'upstream': ['电子'],
                'midstream': ['通信', '计算机'],
                'downstream': ['传媒']
            }
        }
    
    def calculate_event_score(self, event_type, strength, surprise, policy_level):
        level_factor = self.policy_levels.get(policy_level, 0.6)
        surprise_factor = self.surprise_factors.get(surprise, 1.0)
        driver_type = self.event_driver_map.get(event_type, 'A_直接政策')
        driver_factor = self.driver_types.get(driver_type, 1.0)
        return round(strength * surprise_factor * level_factor * driver_factor, 2)
    
    def is_weekday_prediction(self, target_date=None):
        if target_date is None:
            target_date = datetime.now()
        if target_date.weekday() == 0:
            return False
        return target_date.weekday() < 4
    
    def _apply_capital_teeter_totter(self, positive_impacts, negative_impacts):
        strong_styles = set()
        for sector in positive_impacts.keys():
            for style, members in self.sector_groups.items():
                if sector in members:
                    strong_styles.add(style)
        for style in strong_styles:
            if style in self.capital_teeter_totter:
                for target in self.capital_teeter_totter[style]:
                    if target in negative_impacts:
                        negative_impacts[target] = round(negative_impacts[target] - 0.3, 2)
                    else:
                        negative_impacts[target] = -0.3
        return negative_impacts
    
    def after_prediction_update(self, event_type, sector, event_score, predicted_impact, actual_gain, date):
        """预测后自动学习"""
        self.beta_learner.auto_update(event_type, sector, event_score, predicted_impact, actual_gain, date)
    
    def predict(self, events, northbound_flow=None, target_date=None, 
                pre_weekend_gains=None, market_breadth=None, fear_greed_index=None,
                up_count=None, down_count=None, prev_day_returns=None):
        
        if self.is_weekday_prediction(target_date):
            up_beta, down_beta, drain_mul, drain_int = 1.0, 0.5, 0.6, 0.7
            model_name = "周内模型（侧重上涨）"
        else:
            up_beta, down_beta, drain_mul, drain_int = 0.8, 1.2, 1.0, 1.0
            model_name = "周末模型（涨跌平衡）"
        
        processed_events = self.weekend_processor.process_weekend_news(events, target_date or datetime.now())
        
        for event in processed_events:
            if event['event_type'] in ['中东局势', '货币政策', '房地产政策']:
                self.diminishing_tracker.update(event['event_type'])
        
        event_scores = []
        for event in processed_events:
            score = self.calculate_event_score(event['event_type'], event['strength'],
                                               event['surprise'], event.get('policy_level', '部委级'))
            if event['event_type'] in ['中东局势', '货币政策', '房地产政策']:
                score = score * self.diminishing_tracker.get_multiplier(event['event_type'])
            event_scores.append({'event': event['event_type'], 'score': score, 'decay': 1.0})
        
        sector_impacts = {}
        sector_sources = {}
        
        for sector in self.sectors:
            total = 0
            sources = []
            for es in event_scores:
                beta = self.get_beta(es['event'], sector)
                if beta != 0:
                    if beta > 0:
                        beta = beta * up_beta
                    else:
                        beta = beta * down_beta
                    
                    if pre_weekend_gains and target_date:
                        ths_name = MODEL_TO_THS.get(sector, sector)
                        pre_gain = pre_weekend_gains.get(ths_name, 0)
                        if pre_gain > 0:
                            adj_factor = self.expectation_adjuster.get_adjustment_factor(
                                ths_name, es['event'], pre_gain
                            )
                            beta = beta * adj_factor
                    
                    impact = beta * (es['score'] / 3) * es.get('decay', 1.0)
                    total += impact
                    if abs(impact) > 0.005:
                        sources.append({'event': es['event'], 'beta': round(beta, 2), 'impact': impact})
            if abs(total) > 0.03:
                sector_impacts[sector] = total
                if sources:
                    sector_sources[sector] = sources
        
        macro_base = self.rolling_calibrator.get_macro_base(northbound_flow)
        for s in sector_impacts:
            sector_impacts[s] += macro_base
        
        fg_multiplier = self.rolling_calibrator.get_fear_greed_multiplier()
        for s in sector_impacts:
            if sector_impacts[s] > 0:
                sector_impacts[s] *= fg_multiplier
        
        # 回调检测优化
        correction_factor = 1.0
        if prev_day_returns and market_breadth:
            max_gain = max(prev_day_returns.values()) if prev_day_returns else 0
            northbound_change = northbound_flow - 50 if northbound_flow else 0
            factor = self.correction_learner.get_factor(
                max_gain, 0.5, market_breadth, northbound_change
            )
            correction_factor = factor
            if factor < 1.0:
                for s in ['电子', '计算机', '通信']:
                    if s in sector_impacts:
                        sector_impacts[s] *= factor
        
        positive = {s: v for s, v in sector_impacts.items() if v > 0}
        negative_events = {s: v for s, v in sector_impacts.items() if v < 0}
        
        for s, v in positive.items():
            retail = self.retail_ratio.get(s, 0.6)
            positive[s] = round(v * (1 + retail * 0.2), 2)
        
        style_weight = self.rolling_calibrator.get_style_weight
        for s in positive:
            positive[s] = round(positive[s] * style_weight(s, is_up=True), 2)
        
        total_inflow = sum(positive.values())
        total_outflow = total_inflow * self.capital_params['friction_cost'] * drain_mul
        
        beneficiary = set(positive.keys())
        all_victims = set(self.sectors) - beneficiary - set(negative_events.keys())
        high_vuln = [s for s in all_victims if self.sector_vulnerability.get(s, 0) > 0.7]
        victims = high_vuln if high_vuln else list(all_victims)[:15]
        vuln_sum = sum([self.sector_vulnerability.get(s, 1.0) for s in victims]) if victims else 1
        
        negative = {}
        for sector in victims:
            drain_share = self.sector_vulnerability.get(sector, 1.0) / vuln_sum
            base_drain = -total_outflow * drain_share
            macro_adj = self.rolling_calibrator.get_macro_base() * self.macro_sensitivity.get(sector, 0.5)
            final = (base_drain + macro_adj) * drain_int * style_weight(sector, is_up=False)
            final = max(final, self.capital_params['max_single_down'])
            negative[sector] = round(final, 2)
        
        for s, v in negative_events.items():
            negative[s] = round(v, 2)
        
        negative = self._apply_capital_teeter_totter(positive, negative)
        
        all_impacts = {**positive, **negative}
        for s in self.sectors:
            if s not in all_impacts:
                all_impacts[s] = round(macro_base, 2)
        
        sorted_impacts = sorted(all_impacts.items(), key=lambda x: x[1], reverse=True)
        pos_list = [(s, v) for s, v in sorted_impacts if v > 0.02]
        neg_list = [(s, v) for s, v in sorted_impacts if v < -0.02]
        
        ths_gainers = []
        for s, v in pos_list[:20]:
            ths_name = MODEL_TO_THS.get(s, s)
            ths_gainers.append({'sector': ths_name, 'prediction': round(v, 2)})
        
        ths_losers = []
        for s, v in neg_list[:10]:
            ths_name = MODEL_TO_THS.get(s, s)
            ths_losers.append({'sector': ths_name, 'prediction': round(v, 2)})
        
        if len(ths_gainers) < 10:
            for s in self.sectors[:20]:
                if len(ths_gainers) >= 10:
                    break
                ths_name = MODEL_TO_THS.get(s, s)
                if ths_name not in [p['sector'] for p in ths_gainers]:
                    ths_gainers.append({'sector': ths_name, 'prediction': 0.05})
        
        # 特殊事件匹配
        if prev_day_returns is not None:
            prev_day_data = {
                '半导体及元件': prev_day_returns.get('半导体及元件', 0),
                '计算机应用': prev_day_returns.get('计算机应用', 0),
                '通信设备': prev_day_returns.get('通信设备', 0),
                'market_breadth': market_breadth,
                'up_count': up_count,
            }
            matched_patterns = self.special_event_tree.match(prev_day_data, self.rolling_market_data)
            if matched_patterns:
                ths_gainers = self.special_event_tree.apply_downturn(
                    {'top_gainers': ths_gainers, 'top_losers': ths_losers}, 
                    matched_patterns
                )['top_gainers']
        
        # 更新滚动市场数据
        if prev_day_returns is not None:
            self.rolling_market_data.update(
                target_date, prev_day_returns, market_breadth, northbound_flow,
                fear_greed_index, up_count, down_count
            )
        
        synergy = []
        sector_event_counts = {}
        for es in event_scores:
            for sector, beta in self.event_beta.get(es['event'], {}).items():
                if beta > 0 and sector in positive:
                    sector_event_counts[sector] = sector_event_counts.get(sector, 0) + 1
        
        for sector, count in sector_event_counts.items():
            if count >= 2:
                synergy.append({
                    'sector': MODEL_TO_THS.get(sector, sector),
                    'event_count': count,
                    'synergy_type': '多重利好叠加' if count >= 3 else '双重利好'
                })
        
        chain = []
        for es in event_scores:
            if es['event'] in self.industry_chain:
                ic = self.industry_chain[es['event']]
                affected = []
                for pos in ['upstream', 'midstream', 'downstream']:
                    for sec in ic.get(pos, []):
                        if sec in positive:
                            affected.append({
                                'position': pos,
                                'sector': MODEL_TO_THS.get(sec, sec),
                                'impact': positive[sec]
                            })
                if affected:
                    chain.append({
                        'event': es['event'],
                        'chain_name': ic['name'],
                        'path': ic['path'],
                        'affected_sectors': affected
                    })
        
        return {
            'top_gainers': ths_gainers,
            'top_losers': ths_losers,
            'positive_sectors': len(pos_list),
            'negative_sectors': len(neg_list),
            'event_scores': [{'event': e['event'], 'score': e['score']} for e in event_scores],
            'sector_sources': sector_sources,
            'synergy': synergy,
            'chain': chain,
            'version': self.version,
            'model_name': model_name,
            'current_style': self.rolling_calibrator.recent_style,
            'market_state': self.rolling_calibrator.get_market_state(),
            'macro_base': macro_base,
            'fear_greed_index': self.rolling_calibrator.fear_greed_index,
            'event_counts': self.diminishing_tracker.event_counts.copy(),
            'northbound_flow': northbound_flow,
            'correction_factor': correction_factor
        }


def save_model():
    model = FinancialPredictorV2344()
    with open('V23.44_fusion.pkl', 'wb') as f:
        pickle.dump(model, f)
    
    print("=" * 85)
    print("✅ V23.44 融合版已保存")
    print("=" * 85)
    print(f"   版本: {model.version}")
    print(f"   β缩放因子: {model.BETA_SCALE}")
    print(f"   板块数量: {len(model.sectors)}个")
    print("=" * 85)
    print("   融合内容:")
    print("     1. V23.39: 特殊事件二叉树 + 30天滚动数据")
    print("     2. V23.43: β放大(0.7) + 自动学习 + 下跌事件")
    print("=" * 85)
    print("   核心改进:")
    print("     - β缩放因子: 0.4 → 0.7 (+75%)")
    print("     - 新增自动学习模块（β动态更新）")
    print("     - 新增下跌事件库（银行利空、油价下跌等）")
    print("     - 优化回调检测（增加资金流向判断）")
    print("=" * 85)
    return model


if __name__ == "__main__":
    save_model()
